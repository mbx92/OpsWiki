# =============================================================================
# OpsWiki — Production template for Coolify
# Copy to Coolify Environment Variables (or .env on server)
# =============================================================================
#
# Nama produk: OpsWiki
# Tagline: Technical knowledge base for DevOps & IT teams
#
# Generate APP_KEY (run once locally):
#   php artisan key:generate --show
#
# =============================================================================

APP_NAME=OpsWiki
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate_show
APP_DEBUG=false
# Wajib https:// di belakang reverse proxy Coolify (hindari mixed content pada CSS/JS)
APP_URL=https://opswiki.example.com

LOG_CHANNEL=stderr
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL — resource Postgres di Coolify (BUKAN di compose ini)
#
# 1. Coolify → Postgres → salin Internal URL / hostname container
#    Contoh hostname: m2a81yq3ad7hvelheztfqywy  (tanpa http://, tanpa port di host)
# 2. Coolify → Application OpsWiki → Advanced → ✓ Connect to Predefined Network
# 3. Isi user/password/database PERSIS seperti di resource Postgres Coolify
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=m2a81yq3ad7hvelheztfqywy
DB_PORT=5432
# Harus sama dengan database di URL Postgres Coolify (sering "postgres", bukan "opswiki")
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=password
DB_SSLMODE=disable

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.opswiki.example.com

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# SaaS platform
# -----------------------------------------------------------------------------
SAAS_CENTRAL_DOMAIN=opswiki.example.com
SAAS_DEFAULT_TENANT_SLUG=default
SAAS_DEFAULT_CURRENCY=IDR
SAAS_REGISTRATION_ENABLED=true
SAAS_DNS_CNAME_TARGET=opswiki.example.com
SAAS_DNS_A_RECORD_IP=

# -----------------------------------------------------------------------------
# Super admin — Platform Admin login
# Ganti password sebelum deploy production!
# -----------------------------------------------------------------------------
SUPER_ADMIN_NAME=OpsWiki Admin
SUPER_ADMIN_EMAIL=admin@opswiki.com
SUPER_ADMIN_PASSWORD=OpsWiki_SuperAdmin_2026!xK9m
SUPER_ADMIN_SYNC_PASSWORD=false

# Bootstrap seeder otomatis sekali saat deploy pertama (jika tabel plans masih kosong).
# Redeploy berikutnya: hanya migrate, tanpa seed ulang.

# -----------------------------------------------------------------------------
# Mail (opsional)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@opswiki.example.com
MAIL_FROM_NAME=OpsWiki

# -----------------------------------------------------------------------------
# Object storage / MinIO (opsional)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

SENTRY_LARAVEL_DSN=

VITE_APP_NAME=OpsWiki

# Port publik di server (Coolify) → internal container tetap 80
APP_PORT=8009
